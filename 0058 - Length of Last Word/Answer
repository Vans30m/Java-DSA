class Solution {
    public int lengthOfLastWord(String s) {
        s = s.trim();        // to clear last space and other spaces
        int len = 0;
        for(int i=s.length() - 1;i >= 0;i--){
            char c = s.charAt(i);
            if(c != ' '){
                len++;
            }
            else{
                break;
            }
        }
        return len;
    }
}
