/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public boolean isSymmetric(TreeNode root) {
        if(root == null){
            return true;
        }
        else{   // start helper function if tree is not empty
            return isSymmetricHelp(root.left,root.right);
        } 
    }

    public boolean isSymmetricHelp(TreeNode left, TreeNode right){
        if(left == null || right == null) return left == right; // both TreeNodes are null
        if(left.val != right.val) return false; // TreeNodes values do not match
        return isSymmetricHelp(left.left,right.right) && isSymmetricHelp(left.right,right.left);    // check if left's left matches right's right AND left's right matches right's left
    }
}
