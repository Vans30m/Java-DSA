class Solution {
    public int subarraySum(int[] nums, int k) {
        Map<Integer,Integer> map = new HashMap<>();
        map.put(0,1);
        int n=nums.length;
        int sum=0, count=0;
        for(int i=0; i<n; i++){
            sum += nums[i];
            int need = sum-k;
            if(map.containsKey(need))
                count += map.get(need); // if need in map contains then count+1
            map.put(sum,map.getOrDefault(sum,0)+1); // record sum in hashmap => if already in map increase freq by 1 ; else add sum with 1
        }
        return count;
    }
}
