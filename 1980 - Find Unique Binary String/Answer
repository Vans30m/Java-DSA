class Solution {
    public String findDifferentBinaryString(String[] nums) {
        String str = "";
        for(int i=0;i<nums.length;i++){
            char ch = nums[i].charAt(i);    // look at diagonal character position (i,i)
            if(ch == '0'){
                str += '1';
            }
            else{
                str += '0';
            }
        }
        return str;
    }
}
