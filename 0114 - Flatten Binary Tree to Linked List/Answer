/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public void flatten(TreeNode root) {
        flatTree(root, null);
    }
    public TreeNode flatTree(TreeNode root, TreeNode next){
        if(root == null) return next;
        next = flatTree(root.right, next);  // flat right subtree and connect to next
        next = flatTree(root.left, next);   // now flat left subtree and connect to next

        root.right = next;  // attach current node to already flat tree list
        root.left = null;
        return root;
    }
}
