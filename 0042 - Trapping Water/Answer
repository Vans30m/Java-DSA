class Solution {
    public int trap(int[] height) {
        int n = height.length;

        int totalWater = 0;

        int start = 0;
        int end = n-1;

        int leftMax = 0;
        int rightMax = 0;

        while(start < end){
            leftMax = Math.max(leftMax,height[start]);  // tallest wall from left side
            rightMax = Math.max(rightMax,height[end]);  // tallest wall from right side

            if(leftMax < rightMax){ // left wall is shorter than right wall
                totalWater += leftMax - height[start];
                start++;
            }
            else{
                totalWater += rightMax - height[end];
                end--;
            }
        }
        return totalWater;
    }
}
