class Solution {
    public String reverseVowels(String s) {
        char[] word = s.toCharArray();  // string to character array
        int start = 0;
        int end = s.length() - 1;
        String vowels = "aeiouAEIOU";

        while(start < end){
            while(start < end && vowels.indexOf(word[start]) == -1) start++;    // move 'start' pointer forward until it hits a vowel
            while(start < end && vowels.indexOf(word[end]) == -1) end--;    // move 'end' pointer backward until it hits a vowel

            char temp = word[start];    // swaps vowels found at 'start' and 'end'
            word[start] = word[end];
            word[end] = temp;

            start++;
            end--;
        }
        return new String(word);
    }
}
