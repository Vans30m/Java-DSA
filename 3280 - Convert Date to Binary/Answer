class Solution {
    public String convertDateToBinary(String date) {
        String[] str = date.split("-"); // breaks input string into an array
        String res = "";
        for(int i=0;i<str.length;i++){
            String s = Integer.toBinaryString(Integer.parseInt(str[i]));    // Integer.parseInt(str[i]) => Converts the string to integer
        // Integer.toBinaryString() => Takes integer and converts it to binary string
            res += s;
            if(i<str.length-1){
                res += "-";
            }
        }
        return res;
    }
}
